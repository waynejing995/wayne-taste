{
  "type": "object",
  "additionalProperties": false,
  "required": ["verdict", "review_type", "patch_sha256", "findings"],
  "properties": {
    "verdict": {"enum": ["FINDINGS", "NO FINDINGS"]},
    "review_type": {"type": "string", "minLength": 1},
    "patch_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "severity", "confidence", "category", "file", "line",
          "problem", "evidence", "fix"
        ],
        "properties": {
          "severity": {"enum": ["CRITICAL", "INFORMATIONAL"]},
          "confidence": {"type": "integer", "minimum": 1, "maximum": 10},
          "category": {"type": "string", "minLength": 1},
          "file": {"type": "string", "minLength": 1},
          "line": {"type": "integer", "minimum": 1},
          "problem": {"type": "string", "minLength": 1},
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "fix": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
